# zpai 后端环境变量示例。真实值只放在服务机 /home/ydz/apps/zpai/.env，不要提交。

# ---- server ----
PORT=8787
# 前端 console 的来源（CORS / 静态托管）
CONSOLE_ORIGIN=https://zpai.evowit.com
# 对外公开 base，用于生成上传附件 URL
PUBLIC_BASE_URL=https://zpai.evowit.com
# 数据与上传目录
DATA_DIR=./data
UPLOAD_DIR=./uploads

# ---- 账号体系 ----
# JWT 签名密钥，生产请用 openssl rand -hex 32 生成
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_DAYS=30

# ---- 大模型（OpenAI 兼容）----
# 内网：http://100.64.0.5:39000/v1
# 外网：http://api.evowit.com/v1
LLM_BASE_URL=http://100.64.0.5:39000/v1
LLM_API_KEY=ollama
LLM_MODEL=evowit-agent27b
# 关闭模型 thinking，保证返回 message.content
LLM_DISABLE_THINKING=true
# 单张图片 data URL 最大字符数（不截断，超限中文提示重拍）
MAX_IMAGE_CHARS=2500000
# 上下文最多保留多少条历史
MAX_CONTEXT_MESSAGES=12

# ---- 异步任务 ----
# 并发跑报告/错题抽取的最大任务数
TASK_CONCURRENCY=2
