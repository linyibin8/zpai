{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "noEmit": true,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*"]
}
