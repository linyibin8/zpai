    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "@zpai/shared": "*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  },
  "license": "UNLICENSED"
}
