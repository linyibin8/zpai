{
  "name": "zpai",
  "version": "0.1.0",
  "description": "zpai 学习陪伴工具：智能连拍记录学习过程、实时语音问答、错题整理、复习队列、学习画像。",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:console",
    "dev:server": "npm --workspace @zpai/server run dev",
    "dev:console": "npm --workspace @zpai/console run dev",
    "build": "npm-run-all build:shared build:server build:console",
    "build:shared": "npm --workspace @zpai/shared run build",
    "build:server": "npm --workspace @zpai/server run build",
    "build:console": "npm --workspace @zpai/console run build",
    "start": "npm --workspace @zpai/server run start",
    "test": "npm --workspace @zpai/server run test",
    "typecheck": "npm-run-all -p typecheck:shared typecheck:server typecheck:console",
    "typecheck:shared": "npm --workspace @zpai/shared run typecheck",
    "typecheck:server": "npm --workspace @zpai/server run typecheck",
    "typecheck:console": "npm --workspace @zpai/console run typecheck"
  },
  "keywords": [
    "education",
    "study-companion",
    "ios",
    "multimodal",
    "tts",
    "stt",
    "error-book",
    "spaced-repetition"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
